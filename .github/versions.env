# Single place to bump cache-key versions and pinned toolchain versions used by
# the composite actions. Loaded into the job environment (GITHUB_ENV) by
# setup-toolchain and run-tests; lines not of the form NAME=value are ignored.

# Cache-key versions: bump to force a rebuild.
SPP_LIBS_CACHE_VERSION=6
GTEST_PARALLEL_CACHE_VERSION=1

# LLVM release the project links against.
LLVM_LIB_VERSION=22
LLVM_LIB_FULL_VERSION=22.1.8

# GCC whose libstdc++ the clang jobs borrow; must be >= 16.
LIBSTDCXX_GCC_VERSION=16